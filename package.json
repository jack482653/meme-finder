{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "meme-finder",
  "title": "Meme Finder",
  "description": "Search memes by keyword and copy them to the clipboard",
  "icon": "extension-icon.png",
  "author": "user",
  "categories": [
    "Fun"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-meme",
      "title": "Search Meme",
      "description": "Search for memes by keyword and copy inline to clipboard",
      "mode": "view",
      "preferences": [
        {
          "name": "klipyApiKey",
          "type": "password",
          "required": true,
          "title": "Klipy API Key",
          "description": "Get yours free at partner.klipy.com"
        },
        {
          "name": "giphyApiKey",
          "type": "password",
          "required": false,
          "title": "Giphy API Key (fallback)",
          "description": "Optional fallback. Get at developers.giphy.com"
        },
        {
          "name": "maxResults",
          "type": "textfield",
          "required": false,
          "default": "9",
          "title": "Number of Results",
          "description": "Results per search (1–20). Default: 9"
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.103.0",
    "cross-fetch": "^4.1.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "eslint": "^9.22.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "dev": "ray develop",
    "build": "ray build -e dist",
    "lint": "ray lint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "jest"
  }
}
